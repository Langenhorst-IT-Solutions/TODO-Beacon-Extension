{
  "name": "todo-beacon",
  "displayName": "TODO Beacon",
  "description": "Bridges code TODO comments and a managed task list — one task, two faces.",
  "version": "0.1.0",
  "private": true,
  "publisher": "langenhorst-it-solutions",
  "author": {
    "name": "Dominic Langenhorst"
  },
  "license": "MIT",
  "icon": "resources/todo-beacon-icon.png",
  "galleryBanner": {
    "color": "#1B1F3B",
    "theme": "dark"
  },
  "pricing": "Free",
  "repository": {
    "type": "git",
    "url": "https://github.com/B1GSt4R/TODO-Beacon-Extension.git"
  },
  "bugs": {
    "url": "https://github.com/B1GSt4R/TODO-Beacon-Extension/issues"
  },
  "homepage": "https://github.com/B1GSt4R/TODO-Beacon-Extension#readme",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "todo",
    "fixme",
    "task",
    "task list",
    "taskpaper",
    "markdown",
    "comments",
    "checklist",
    "productivity"
  ],
  "badges": [
    {
      "url": "https://github.com/B1GSt4R/TODO-Beacon-Extension/actions/workflows/ci.yml/badge.svg?branch=dev",
      "href": "https://github.com/B1GSt4R/TODO-Beacon-Extension/actions/workflows/ci.yml",
      "description": "CI status"
    },
    {
      "url": "https://img.shields.io/github/license/B1GSt4R/TODO-Beacon-Extension",
      "href": "https://github.com/B1GSt4R/TODO-Beacon-Extension/blob/main/LICENSE",
      "description": "License"
    }
  ],
  "capabilities": {
    "untrustedWorkspaces": {
      "supported": true
    },
    "virtualWorkspaces": true
  },
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "todo-beacon",
          "title": "TODO Beacon",
          "icon": "resources/todo-beacon-activitybar.svg"
        }
      ]
    },
    "views": {
      "todo-beacon": [
        {
          "id": "todo-beacon.codeView",
          "name": "Code TODOs"
        },
        {
          "id": "todo-beacon.listView",
          "name": "Task List"
        }
      ]
    },
    "commands": [
      {
        "command": "todo-beacon.refresh",
        "title": "Refresh TODOs",
        "icon": "$(refresh)",
        "category": "TODO Beacon"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "todo-beacon.refresh",
          "when": "view == todo-beacon.codeView || view == todo-beacon.listView",
          "group": "navigation"
        }
      ]
    },
    "configuration": {
      "title": "TODO Beacon",
      "properties": {
        "todo-beacon.tags": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            "TODO",
            "FIXME",
            "BUG",
            "HACK",
            "NOTE",
            "TEST",
            "DEBUG",
            "OPTIMIZE",
            "PERF",
            "REVIEW",
            "IDEA",
            "WARNING",
            "WARN",
            "DEPRECATED",
            "XXX"
          ],
          "description": "Comment tags to detect in source files."
        },
        "todo-beacon.taskFile": {
          "type": "string",
          "default": "",
          "description": "Path to the task file relative to the workspace root. Leave empty to auto-detect (tries tasks.todo → TODO.md → todo.md → TASKS.md → tasks.md in order). Supports TaskPaper (.todo) and Markdown (.md) formats."
        },
        "todo-beacon.exclude": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            "**/node_modules/**",
            "**/.git/**",
            "**/dist/**",
            "**/build/**",
            "**/wwwroot/**",
            "**/assets/**",
            "**/out/**",
            "**/.vscode-test/**",
            "**/.angular/**",
            "**/.next/**",
            "**/.nuxt/**",
            "**/.turbo/**",
            "**/.cache/**",
            "**/.parcel-cache/**",
            "**/__pycache__/**",
            "**/.pytest_cache/**",
            "**/.mypy_cache/**",
            "**/.ruff_cache/**",
            "**/.tox/**",
            "**/.gradle/**",
            "**/.dart_tool/**",
            "**/target/**"
          ],
          "description": "Glob patterns to exclude from code scanning."
        },
        "todo-beacon.maxFileSizeKb": {
          "type": "number",
          "default": 1024,
          "description": "Maximum file size in KB to scan. Larger files are skipped."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "node esbuild.js",
    "watch": "node esbuild.js --watch",
    "package": "npm run check-types && npm run lint && node esbuild.js --production",
    "compile-tests": "tsc -p tsconfig.json --outDir out",
    "watch-tests": "tsc -p tsconfig.json -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile",
    "check-types": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vscode-test",
    "prepare": "husky"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.0.0",
    "@commitlint/config-conventional": "^19.0.0",
    "@semantic-release/changelog": "^6.0.0",
    "@semantic-release/exec": "^6.0.0",
    "@semantic-release/git": "^10.0.0",
    "@semantic-release/github": "^10.0.0",
    "@types/mocha": "^10.0.0",
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.90.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "@vscode/test-cli": "^0.0.10",
    "@vscode/test-electron": "^2.4.0",
    "@vscode/vsce": "^3.0.0",
    "esbuild": "^0.24.0",
    "eslint": "^8.0.0",
    "husky": "^9.0.0",
    "semantic-release": "^24.0.0",
    "typescript": "^5.0.0"
  }
}
